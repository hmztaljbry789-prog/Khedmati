# ── Server ──
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/Khedmati
# Required. Use a long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=
# Frontend origin allowed by CORS.
CLIENT_URL=http://localhost:5173

# ── Cloudinary media storage ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Admin seeding (npm run seed:admin) ──
ADMIN_EMAIL=admin@khedmati.ps
# Required by the seed script. Minimum 8 characters.
ADMIN_PASSWORD=

# ── Mail (password reset) — optional ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=Khedmati
MAIL_FROM=

# ── Web Push notifications — optional ──
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@khedmati.app
